    "version": "0.2.0",
    "configurations": [
        {
            "name": "Attach by Process ID",
            "processId": "${command:PickProcess}",
            "request": "attach",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "type": "node"
        },
        {
            "name": "Electron Main",
            "program": "${workspaceFolder}/main.js",
            "request": "launch",
            "runtimeExecutable": "electron",
            "skipFiles": [
                "node_modules/**"
            ],
            "type": "node"
        },
        {
            "name": "Attach to Node.js",
            "port": 9229,
            "request": "attach",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "type": "node"
        },

        {
            "name": "Launch Edge",
            "request": "launch",
            "type": "msedge",
            "url": "http://localhost:8080",
            "webRoot": "c:\\Users\\NEETECH\\OneDrive\\Desktop\\odm-ur-gov-iq-main"
        },
        {
            "name": "Launch Chrome",
            "request": "launch",
            "type": "chrome",
            "url": "http://localhost:8080",
            "webRoot": "c:\\Users\\NEETECH\\OneDrive\\Desktop\\odm-ur-gov-iq-main"
        },
        
        {
            "name": "Attach to Chrome",
            "port": 9222,
            "request": "attach",
